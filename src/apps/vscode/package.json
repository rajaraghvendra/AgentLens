{
  "name": "agentlens",
  "displayName": "◊ AgentLens: AI Cost Tracker",
  "description": "Live AI token and cost tracking in your VS Code status bar",
  "version": "0.1.6",
  "publisher": "rajaraghvendra",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajaraghvendra/AgentLens.git"
  },
  "homepage": "https://github.com/rajaraghvendra/AgentLens",
  "bugs": {
    "url": "https://github.com/rajaraghvendra/AgentLens/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Developer Tools"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:agentlens.openDashboard",
    "onCommand:agentlens.showOutput",
    "onCommand:agentlens.setBudget"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentlens.openDashboard",
        "title": "Open AgentLens Dashboard"
      },
      {
        "command": "agentlens.showOutput",
        "title": "Show AgentLens Output"
      },
      {
        "command": "agentlens.setBudget",
        "title": "Set AgentLens Budget"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "AgentLens",
      "properties": {
        "agentlens.pollingInterval": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 300,
          "description": "Polling interval in seconds to fetch live costs"
        },
        "agentlens.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to CLI (blank = auto-detect from workspace, or 'agentlens' for global install)"
        },
        "agentlens.onClickAction": {
          "type": "string",
          "default": "openDashboard",
          "enum": [
            "openDashboard",
            "showOutput",
            "none"
          ],
          "description": "Action when clicking the status bar"
        },
        "agentlens.dailyBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Daily budget in USD (0 to disable)"
        },
        "agentlens.monthlyBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Monthly budget in USD (0 to disable)"
        },
        "agentlens.notifyOnBudgetWarning": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when budget threshold reached"
        },
        "agentlens.claudeCodeBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Daily budget for Claude Code in USD"
        },
        "agentlens.opencodeBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Daily budget for OpenCode in USD"
        },
        "agentlens.codexBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Daily budget for Codex in USD"
        },
        "agentlens.cursorBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Daily budget for Cursor in USD"
        },
        "agentlens.copilotBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Daily budget for GitHub Copilot in USD"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./tsconfig.json",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.19.22",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {}
}
