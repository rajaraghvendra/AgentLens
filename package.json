{
  "name": "@rajaraghvendra/agentlens",
  "version": "0.1.18",
  "description": "Local-first AI developer analytics — parse, classify, cost-track, and optimize your AI coding sessions.",
  "type": "module",
  "main": "dist/core/engine.js",
  "types": "dist/core/engine.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/engine.d.ts",
      "import": "./dist/core/engine.js"
    },
    "./core-types": {
      "types": "./dist/core-types/index.d.ts",
      "import": "./dist/core-types/index.js"
    },
    "./core-engine": {
      "types": "./dist/core-engine/index.d.ts",
      "import": "./dist/core-engine/index.js"
    },
    "./providers": {
      "types": "./dist/providers/public.d.ts",
      "import": "./dist/providers/public.js"
    },
    "./local-runtime": {
      "types": "./dist/local-runtime/index.d.ts",
      "import": "./dist/local-runtime/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/adapters",
    "dist/apps/cli",
    "dist/apps/dashboard-runtime",
    "dist/apps/tui",
    "dist/config",
    "dist/core",
    "dist/core-engine",
    "dist/core-types",
    "dist/local-runtime",
    "dist/providers",
    "src/apps/tui",
    "dist/types",
    "dist/utils",
    "scripts",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "agentlens": "./dist/apps/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rajaraghvendra/AgentLens.git"
  },
  "keywords": [
    "ai",
    "analytics",
    "developer-tools",
    "claude",
    "cursor",
    "codex",
    "copilot",
    "cost-tracking",
    "token-usage"
  ],
  "author": "rajaraghvendra",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "typesVersions": {
    "*": {
      "core-types": [
        "dist/core-types/index.d.ts"
      ],
      "core-engine": [
        "dist/core-engine/index.d.ts"
      ],
      "providers": [
        "dist/providers/public.d.ts"
      ],
      "local-runtime": [
        "dist/local-runtime/index.d.ts"
      ]
    }
  },
  "scripts": {
    "sync:version": "node scripts/sync-versions.mjs",
    "postinstall": "node scripts/check-sqlite.mjs",
    "dev": "node --import tsx src/apps/cli/index.ts",
    "tui": "node --import tsx src/apps/tui/index.ts",
    "build:core": "node ./node_modules/typescript/bin/tsc && node scripts/copy-assets.mjs",
    "build:dashboard-runtime": "node scripts/package-dashboard-runtime.mjs",
    "build": "npm run sync:version && npm run build:core",
    "build:all": "npm run sync:version && npm run build:core && npm --prefix src/apps/web run build && npm run build:dashboard-runtime",
    "prepublishOnly": "npm run build:all",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit",
    "dashboard": "node ./dist/apps/cli/index.js dashboard",
    "dashboard:dev": "npm --prefix src/apps/web run dev"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@types/vscode": "^1.80.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "next": "^15.5.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "lucide-react": "^1.8.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
